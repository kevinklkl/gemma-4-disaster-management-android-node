<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardBackgroundColor="@color/akbay_paper_warm"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="#C4B79C">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header: Order ID and Last Updated -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvOrderId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ORD-0000"
                android:textColor="@color/akbay_ink"
                android:textSize="20sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:gravity="end"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LAST UPDATED"
                    android:textColor="@color/akbay_ash"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvLastUpdated"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/akbay_ink"
                    android:textSize="12sp" />
            </LinearLayout>
        </RelativeLayout>

        <!-- Location Row -->
        <TextView
            android:id="@+id/tvLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Unknown"
            android:textColor="@color/akbay_ash"
            android:textSize="13sp"
            app:drawableStartCompat="@android:drawable/ic_menu_mylocation"
            android:drawablePadding="6dp"
            app:drawableTint="@color/akbay_ash" />

        <!-- People/Source and Urgency Badge -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvPeopleCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 people"
                    android:textColor="@color/akbay_ash"
                    android:textSize="13sp"
                    app:drawableStartCompat="@android:drawable/ic_menu_myplaces"
                    android:drawablePadding="6dp"
                    app:drawableTint="@color/akbay_ash" />

                <TextView
                    android:id="@+id/tvSource"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="sms"
                    android:textColor="@color/akbay_ash"
                    android:textSize="13sp"
                    app:drawableStartCompat="@android:drawable/sym_action_email"
                    android:drawablePadding="6dp"
                    app:drawableTint="@color/akbay_ash" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvUrgencyBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:background="@drawable/pill_background"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:text="CRITICAL"
                android:textColor="@color/akbay_bone"
                android:textSize="11sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- Progress Section -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:background="#D2C8B1" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/tvProgressPercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="0% +?"
                android:textColor="@color/akbay_ash"
                android:textSize="11sp" />
        </RelativeLayout>

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginTop="4dp"
            android:progress="0"
            android:progressTint="@color/akbay_primary"
            android:progressBackgroundTint="#D2C8B1" />

        <!-- Items List Container -->
        <LinearLayout
            android:id="@+id/itemsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical" />

        <!-- Action Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDispatch"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="pack items to dispatch"
            android:textAllCaps="false"
            android:textColor="@color/akbay_ink"
            app:backgroundTint="#DFD3B8"
            app:cornerRadius="4dp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
