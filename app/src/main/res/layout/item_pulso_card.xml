<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardBackgroundColor="@color/akbay_card"
    app:cardCornerRadius="8dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/akbay_paper_edge">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top Urgency Bar -->
        <View
            android:id="@+id/urgencyBar"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:background="@color/akbay_tabang" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Header: Order ID and Last Updated -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tvOrderId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ORD-0000"
                    android:textColor="@color/akbay_ink"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:background="@drawable/pill_background"
                    android:backgroundTint="@color/akbay_divider"
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:text="LAST UPDATED"
                        android:textColor="@color/akbay_ash"
                        android:textSize="9sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:src="@drawable/ic_lucide_clock"
                            app:tint="@color/akbay_ash" />

                        <TextView
                            android:id="@+id/tvLastUpdated"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="—"
                            android:textColor="@color/akbay_ink"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </RelativeLayout>

            <!-- Location Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_lucide_map_pin"
                    app:tint="@color/akbay_ash" />

                <TextView
                    android:id="@+id/tvLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="Unknown"
                    android:textColor="@color/akbay_ash"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- People/Source and Urgency Badge -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_lucide_users"
                        app:tint="@color/akbay_ash" />

                    <TextView
                        android:id="@+id/tvPeopleCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="0 people"
                        android:textColor="@color/akbay_ash"
                        android:textSize="14sp" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="16dp"
                        android:src="@drawable/ic_lucide_smartphone"
                        app:tint="@color/akbay_ash" />

                    <TextView
                        android:id="@+id/tvSource"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="sms"
                        android:textColor="@color/akbay_ash"
                        android:textSize="14sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvUrgencyBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:background="@drawable/pill_background"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:text="CRITICAL"
                    android:textColor="@color/akbay_tabang"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <!-- Progress Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ProgressBar
                    android:id="@+id/progressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="6dp"
                    android:layout_weight="1"
                    android:progress="0"
                    android:progressTint="@color/akbay_primary"
                    android:progressBackgroundTint="@color/akbay_divider" />

                <TextView
                    android:id="@+id/tvProgressPercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="0% +?"
                    android:textColor="@color/akbay_ash"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Items List Container -->
            <LinearLayout
                android:id="@+id/itemsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical" />

            <!-- Action Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDispatch"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:text="pack items to dispatch"
                android:textAllCaps="false"
                android:textColor="@color/akbay_paper"
                android:textSize="15sp"
                android:textStyle="bold"
                app:backgroundTint="@color/akbay_header"
                app:cornerRadius="8dp"
                app:icon="@drawable/ic_lucide_send"
                app:iconGravity="textStart"
                app:iconPadding="10dp"
                app:iconTint="@color/akbay_paper" />

        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
